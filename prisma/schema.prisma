// Prisma schema — Allura
//
// Allura is a Hebrew-only, multi-tenant SaaS for beauty & wellness businesses.
// Model and field names are kept in developer-friendly English; all user-facing
// Hebrew lives in the application layer, not in the schema.
//
// Design principles (see CLAUDE.md):
//   * Generic data model — no domain-specific treatment models.
//   * Multi-tenant isolation — every tenant-owned model carries `businessId`,
//     and every query must be scoped by the current business.
//   * Core entities are real columns; JSON is used only for flexible
//     settings / metadata / snapshots.
//   * IDs are cuid strings; money uses Decimal(10,2); timestamps use DateTime.
//
// Opening-hours representation (AvailabilityRule / AvailabilityException):
//   Local opening hours are stored as integer "minutes since midnight"
//   (0–1439, where 09:00 = 540, 17:30 = 1050). This is timezone-agnostic,
//   trivial to compare/sort, and avoids the ambiguity of stuffing a wall-clock
//   time into a DateTime. The actual calendar timezone lives on Business.timezone.
//   `weekday` follows JS getDay() and the Israeli week: 0 = Sunday … 6 = Saturday.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// Role of a user within a specific business (membership-scoped).
enum BusinessUserRole {
  owner
  admin
  staff
}

/// Beauty/wellness category keys. Backs the seeded BusinessCategory reference
/// table and the optional Service.categoryKey field.
enum BusinessCategoryKey {
  nails
  brows
  lashes
  hair
  makeup
  cosmetics
  laser
  aesthetics
  massage
  spa
  permanent_makeup
  other
}

enum BookingStatus {
  pending
  approved
  completed
  cancelled
  no_show
  rescheduled
}

/// Where a booking originated from.
enum BookingSource {
  public
  manual
  waitlist
}

/// Status of an individual Payment record.
enum PaymentStatus {
  not_required
  pending
  paid
  failed
  refunded
}

/// What a payment represents.
enum PaymentType {
  full
  balance
  refund
}

/// Online payment / clearing provider for booking payments.
/// `mock` is the safe dev/test default; real providers are added incrementally.
enum PaymentProviderKind {
  mock
  payplus
  grow_meshulam
  tranzila
  disabled
}

/// Whether a booking requires upfront online payment.
enum PaymentRequirement {
  none
  full_payment
}

/// Connection state of a business's payment provider credentials.
enum PaymentConnectionStatus {
  not_connected
  active
  error
}

/// Lifecycle of a single hosted-payment-link booking payment.
enum BookingPaymentStatus {
  pending
  payment_link_created
  paid
  failed
  cancelled
  expired
  refunded
}

enum MessageTemplateType {
  booking_confirmation
  booking_reminder
  booking_cancelled
  booking_rescheduled
  after_treatment
  rebook_reminder
  empty_slot_offer
  waitlist_offer
}

enum ReminderStatus {
  pending
  sent
  cancelled
  failed
}

enum ReminderType {
  booking_reminder
  after_treatment
  rebook_reminder
  custom
}

enum WaitlistStatus {
  active
  notified
  booked
  cancelled
  expired
}

enum RecommendationStatus {
  active
  dismissed
  done
}

/// Rule-based recommendation categories (V1 is rule-based, not real AI).
enum RecommendationType {
  client_not_returned
  empty_slot
  repeat_cancellations
  no_show
  revenue_drop
  waitlist_opportunity
}

enum AvailabilityExceptionType {
  closed
  custom_hours
}

enum ExpenseCategory {
  rent
  materials
  equipment
  marketing
  staff
  utilities
  processing_fees
  software
  other
}

enum SubscriptionPlan {
  basic
  pro
}

/// Lifecycle status of a business's Allura subscription.
enum SubscriptionStatus {
  trial
  active
  discounted
  suspended
  cancelled
  pending_payment
}

enum DiscountType {
  none
  fixed
  percentage
}

enum WhatsAppProvider {
  dev_mock
  meta_cloud
  twilio
  green_api
}

enum WhatsAppConnectionStatus {
  not_connected
  pending
  active
  error
}

enum AutomationType {
  win_back
  morning_reminder
  review_request
  manual
  booking_confirmation
}

enum AutomationRunStatus {
  running
  completed
  failed
  partial
}

enum AutomationMessageStatus {
  queued
  sent
  delivered
  read
  failed
  skipped
}

enum AutomationOfferType {
  none
  discount_10
  upgrade
  special_slot
  custom
}

// ---------------------------------------------------------------------------
// Global (non-tenant) models
// ---------------------------------------------------------------------------

/// Global account. NOT tenant-owned — a user can belong to several businesses
/// through BusinessUser.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships BusinessUser[]
}

/// Seeded reference table of beauty/wellness categories. NOT tenant-owned.
model BusinessCategory {
  id        String              @id @default(cuid())
  key       BusinessCategoryKey @unique
  nameHe    String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  businesses BusinessCategoryOnBusiness[]
}

// ---------------------------------------------------------------------------
// Tenant root
// ---------------------------------------------------------------------------

/// The tenant. Owns essentially all business data in the system.
model Business {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  phone       String?
  description String?
  timezone    String   @default("Asia/Jerusalem")
  city        String?
  area        String?
  addressNote String?
  /// Flexible, non-core business settings only (branding, preferences, etc.).
  settings    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Public page customisation fields
  logoUrl              String?
  coverImageUrl        String?
  instagramUrl         String?
  facebookUrl          String?
  brandColor           String?
  introMessage         String?
  /// Section visibility toggles for the public booking page
  showServices         Boolean @default(true)
  showPrices           Boolean @default(true)
  showHours            Boolean @default(true)
  showReviews          Boolean @default(false)
  showGallery          Boolean @default(false)
  showCancellationPolicy Boolean @default(true)
  showPhone            Boolean @default(true)
  showAddress          Boolean @default(true)

  members                BusinessUser[]
  categories             BusinessCategoryOnBusiness[]
  services               Service[]
  clients                Client[]
  bookings               Booking[]
  availabilityRules      AvailabilityRule[]
  availabilityExceptions AvailabilityException[]
  payments               Payment[]
  cancellationPolicy     CancellationPolicy?
  messageTemplates       MessageTemplate[]
  reminders              Reminder[]
  waitlistEntries        WaitlistEntry[]
  recommendations        Recommendation[]
  galleryImages          GalleryImage[]
  clientReviews          ClientReview[]
  expenses               Expense[]
  subscription           BusinessSubscription?
  whatsappConnection     WhatsAppConnection?
  automationSettings     AutomationSetting[]
  automationRuns         AutomationRun[]
  automationMessages     AutomationMessage[]
  paymentSettings        BusinessPaymentSettings?
  paymentConnection      PaymentProviderConnection?
  bookingPayments        BookingPayment[]
}

/// Membership join between a global User and a Business, carrying the role.
model BusinessUser {
  id         String           @id @default(cuid())
  userId     String
  businessId String
  role       BusinessUserRole @default(owner)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
}

/// Many-to-many join between a Business and the categories it belongs to.
model BusinessCategoryOnBusiness {
  id         String   @id @default(cuid())
  businessId String
  categoryId String
  createdAt  DateTime @default(now())

  business Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category BusinessCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([businessId, categoryId])
  @@index([businessId])
  @@index([categoryId])
}

// ---------------------------------------------------------------------------
// Business core
// ---------------------------------------------------------------------------

/// A bookable service offered by a business. Generic for any treatment type.
model Service {
  id                  String               @id @default(cuid())
  businessId          String
  /// Optional categorisation; reuses the global category key enum.
  categoryKey         BusinessCategoryKey?
  name                String
  description         String?
  durationMinutes     Int
  price               Decimal              @db.Decimal(10, 2)
  bufferBeforeMinutes Int                  @default(0)
  bufferAfterMinutes  Int                  @default(0)
  /// Optional manual market price range set by the business owner (no external market data).
  marketMinPrice      Decimal?             @db.Decimal(10, 2)
  marketAveragePrice  Decimal?             @db.Decimal(10, 2)
  marketMaxPrice      Decimal?             @db.Decimal(10, 2)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  waitlistEntries WaitlistEntry[]

  @@index([businessId])
  @@index([businessId, isActive])
}

/// A client of a business. Phone is stored both as entered and normalized
/// (e.g. E.164) so lookups and the per-business uniqueness check are reliable.
model Client {
  id                String    @id @default(cuid())
  businessId        String
  fullName          String
  phone             String
  normalizedPhone   String
  email             String?
  notes             String?
  lastVisitAt       DateTime?
  totalBookings     Int       @default(0)
  noShowCount       Int       @default(0)
  cancellationCount Int       @default(0)
  totalSpent        Decimal   @default(0) @db.Decimal(10, 2)
  /// Client has consented to receive WhatsApp messages
  whatsappOptIn     Boolean   @default(false)
  /// Client has consented to receive marketing messages
  marketingOptIn    Boolean   @default(false)
  /// Set when client unsubscribes from automated messages
  unsubscribedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  business           Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings           Booking[]
  payments           Payment[]
  waitlistEntries    WaitlistEntry[]
  recommendations    Recommendation[]
  automationMessages AutomationMessage[]
  bookingPayments    BookingPayment[]

  @@unique([businessId, normalizedPhone])
  @@index([businessId])
  @@index([businessId, phone])
  @@index([businessId, normalizedPhone])
}

/// A booking. Price/duration are snapshotted at creation time so that
/// later changes to the Service do not rewrite history.
model Booking {
  id                       String        @id @default(cuid())
  businessId               String
  clientId                 String
  serviceId                String
  startTime                DateTime
  endTime                  DateTime
  status                   BookingStatus @default(pending)
  source                   BookingSource @default(public)
  priceSnapshot            Decimal       @db.Decimal(10, 2)
  durationMinutesSnapshot  Int
  notes                    String?
  cancellationReason       String?
  cancelledAt              DateTime?
  completedAt              DateTime?
  noShowAt                 DateTime?
  /// "pending" | "paid" — set when a late cancellation fee applies; null when not applicable
  lateCancellationFeeStatus String?
  rescheduledFromBookingId String?
  /// WhatsApp automation tracking — prevent duplicate sends
  confirmationSentAt       DateTime?
  reminderSentAt           DateTime?
  reviewRequestSentAt      DateTime?
  /// Owner notification tracking — set once the business owner has been alerted
  /// about this (public) booking request, to prevent duplicate notifications.
  ownerNotifiedAt          DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  business           Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client             Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service            Service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  // Self-relation: when a booking is rescheduled, the new booking points back
  // at the original one it replaced.
  rescheduledFrom    Booking?           @relation("BookingReschedule", fields: [rescheduledFromBookingId], references: [id], onDelete: SetNull)
  rescheduledTo      Booking[]          @relation("BookingReschedule")
  payments           Payment[]
  reminders          Reminder[]
  recommendations    Recommendation[]
  automationMessages AutomationMessage[]
  bookingPayment     BookingPayment?

  @@index([businessId, startTime])
  @@index([businessId, status])
  @@index([businessId, clientId])
  @@index([businessId, serviceId])
}

// ---------------------------------------------------------------------------
// Availability
// ---------------------------------------------------------------------------

/// Recurring weekly opening hours. One row per open window per weekday
/// (a day may have multiple windows, e.g. morning + evening).
model AvailabilityRule {
  id           String   @id @default(cuid())
  businessId   String
  /// 0 = Sunday … 6 = Saturday (JS getDay, Israeli week order).
  weekday      Int
  /// Minutes since midnight, 0–1439 (e.g. 09:00 = 540).
  startMinutes Int
  endMinutes   Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, weekday])
}

/// A one-off override for a specific date: either fully closed, or open with
/// custom hours (startMinutes/endMinutes required when type = custom_hours).
model AvailabilityException {
  id           String                    @id @default(cuid())
  businessId   String
  date         DateTime                  @db.Date
  type         AvailabilityExceptionType
  startMinutes Int?
  endMinutes   Int?
  reason       String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date])
  @@index([businessId, date])
}

// ---------------------------------------------------------------------------
// Payments & policy
// ---------------------------------------------------------------------------

/// A payment record. V1 is manual tracking only (no real provider).
model Payment {
  id           String        @id @default(cuid())
  businessId   String
  bookingId    String
  clientId     String?
  amount       Decimal       @db.Decimal(10, 2)
  currency     String        @default("ILS")
  type         PaymentType
  status       PaymentStatus @default(pending)
  method       String        @default("manual")
  markedPaidAt DateTime?
  refundedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([businessId, bookingId])
}

/// One cancellation policy per business.
model CancellationPolicy {
  id                           String   @id @default(cuid())
  businessId                   String   @unique
  enabled                      Boolean  @default(false)
  policyText                   String?
  minNoticeHours               Int?
  /// Hours before appointment that mark a cancellation as "late" (6, 12, 24, 48, or custom)
  lateCancellationHours        Int?
  /// "none" | "fixed" | "percentage"
  lateCancellationFeeType      String   @default("none")
  /// Fixed fee amount in ILS
  lateCancellationFeeAmount    Decimal? @db.Decimal(10, 2)
  /// Percentage of service price (0–100)
  lateCancellationFeePercentage Decimal? @db.Decimal(5, 2)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Messaging & engagement
// ---------------------------------------------------------------------------

/// System-wide default WhatsApp-ready templates (Hebrew). NOT tenant-owned —
/// exactly one default per template type, enforced by the unique `type`.
/// V1 generates text only, no real WhatsApp API.
model SystemMessageTemplate {
  id        String              @id @default(cuid())
  type      MessageTemplateType @unique
  title     String
  body      String
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

/// Per-business WhatsApp-ready template overrides. Stores ONLY business-specific
/// customisations — system defaults live in SystemMessageTemplate.
///
/// Template resolution rule (when generating a message for a business):
///   1. Look up MessageTemplate by (businessId, type).
///   2. If none exists, fall back to SystemMessageTemplate by type.
model MessageTemplate {
  id         String              @id @default(cuid())
  businessId String
  type       MessageTemplateType
  title      String
  body       String
  isActive   Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, type])
  @@index([businessId])
  @@index([businessId, type])
}

/// A scheduled reminder tied to a booking.
model Reminder {
  id         String         @id @default(cuid())
  businessId String
  bookingId  String
  type       ReminderType
  dueAt      DateTime
  status     ReminderStatus @default(pending)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([businessId, dueAt])
  @@index([businessId, status])
}

/// A client waiting for an earlier/available slot.
model WaitlistEntry {
  id            String         @id @default(cuid())
  businessId    String
  clientId      String
  serviceId     String?
  preferredFrom DateTime?
  preferredTo   DateTime?
  notes         String?
  status        WaitlistStatus @default(active)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service  Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([businessId, status])
}

// ---------------------------------------------------------------------------
// Public page assets
// ---------------------------------------------------------------------------

/// An image in the business's public gallery (URL-based for V1, upload later).
model GalleryImage {
  id         String   @id @default(cuid())
  businessId String
  imageUrl   String
  caption    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

/// A client review shown on the public page (owner-approved, owner-entered for V1).
model ClientReview {
  id         String   @id @default(cuid())
  businessId String
  clientName String
  reviewText String
  rating     Int      @default(5)
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, isApproved])
}

/// A rule-based recommendation surfaced to the business owner.
model Recommendation {
  id               String               @id @default(cuid())
  businessId       String
  type             RecommendationType
  status           RecommendationStatus @default(active)
  title            String
  body             String
  priority         Int?
  relatedClientId  String?
  relatedBookingId String?
  /// Snapshot of the data that triggered the recommendation (metadata only).
  dataSnapshot     Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client   Client?  @relation(fields: [relatedClientId], references: [id], onDelete: SetNull)
  booking  Booking? @relation(fields: [relatedBookingId], references: [id], onDelete: SetNull)

  @@index([businessId, status])
  @@index([businessId, type])
}

/// A manually tracked business expense. V1 is owner-entered only; no payment provider.
model Expense {
  id          String          @id @default(cuid())
  businessId  String
  amount      Decimal         @db.Decimal(10, 2)
  description String
  category    ExpenseCategory
  date        DateTime        @db.Date
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, date])
}

/// Internal subscription / billing record for an Allura customer business.
/// Managed exclusively by platform admins — never visible to business owners.
model BusinessSubscription {
  id             String             @id @default(cuid())
  businessId     String             @unique
  plan           SubscriptionPlan   @default(basic)
  status         SubscriptionStatus @default(trial)
  monthlyPrice   Decimal            @default(149) @db.Decimal(10, 2)
  discountType   DiscountType       @default(none)
  discountValue  Decimal?           @db.Decimal(10, 2)
  discountNote   String?
  trialStartedAt DateTime?
  trialEndsAt    DateTime?
  suspendedAt    DateTime?
  cancelledAt    DateTime?
  /// Internal admin notes — never shown to the business owner.
  adminNotes     String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([plan])
}

// ---------------------------------------------------------------------------
// WhatsApp automation — Win-back
// ---------------------------------------------------------------------------

/// Stores the WhatsApp Business API connection for a tenant.
/// Mode A (env fallback): useEnvFallback=true, token comes from META_WHATSAPP_ACCESS_TOKEN env var.
/// Mode B (Embedded Signup, future): useEnvFallback=false, token stored in accessTokenEncrypted.
/// Future: Meta Embedded Signup will create/update WhatsAppConnection per business via onboarding flow.
model WhatsAppConnection {
  id                   String                   @id @default(cuid())
  businessId           String                   @unique
  provider             WhatsAppProvider         @default(dev_mock)
  status               WhatsAppConnectionStatus @default(not_connected)
  /// Display phone number for owner UI (e.g. +972501234567)
  phoneNumber          String?
  /// Meta phone number ID used for API calls (e.g. "123456789012345") — different from display number
  phoneNumberId        String?
  /// Masked display phone shown in UI (e.g. "+972 50-123-****")
  displayPhoneNumber   String?
  /// WhatsApp Business Account ID (Meta Cloud API)
  wabaId               String?
  /// Encrypted provider access token — never returned to the client
  accessTokenEncrypted String?
  /// When true, the access token comes from META_WHATSAPP_ACCESS_TOKEN env var (Mode A / testing).
  /// When false, token must come from accessTokenEncrypted (Mode B / Embedded Signup).
  useEnvFallback       Boolean                  @default(false)
  /// When the connection was last verified successfully against the provider API
  lastVerifiedAt       DateTime?
  /// Last error message — safe to display in admin UI (never contains credentials)
  lastError            String?
  /// When the connection was established (status changed to active)
  connectedAt          DateTime?
  /// When the connection was last lost (status changed from active)
  disconnectedAt       DateTime?
  /// Access token expiry — for future long-lived tokens from Embedded Signup
  tokenExpiresAt       DateTime?
  /// How the owner chose to onboard this number in Embedded Signup. One of:
  /// "new_number" | "existing_business_app" | "personal" | "unknown".
  /// Reflects the owner's stated intent (Meta does not reliably report the real
  /// path back), and is used only for owner-facing guidance + the confirmation step.
  connectionSource     String?
  /// When the owner/admin explicitly confirmed the connected display number is
  /// correct. While a connection created through the guided flow (connectionSource
  /// set) has this null, real sends are blocked — see the WhatsApp resolver.
  numberConfirmedAt    DateTime?
  /// Timestamp of the last webhook event received from Meta (any type)
  lastWebhookReceivedAt DateTime?
  /// Timestamp of the last delivery status event received via webhook
  lastDeliveryEventAt  DateTime?
  /// Timestamp of the last read status event received via webhook
  lastReadEventAt      DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

/// Per-business, per-type automation configuration.
model AutomationSetting {
  id              String              @id @default(cuid())
  businessId      String
  type            AutomationType
  enabled         Boolean             @default(false)
  /// Days of inactivity before a client is eligible (30/45/60/90/custom)
  thresholdDays   Int                 @default(45)
  /// Hour of day (0–23, local business timezone) to send messages
  sendHour        Int                 @default(10)
  /// Owner-editable message template body with {variables}
  messageTemplate  String?
  /// Meta-approved WhatsApp template name (required for real Meta Cloud API sends)
  templateName     String?
  /// BCP 47 language code matching the approved template (default: he)
  templateLanguage String?             @default("he")
  /// Last known Meta approval status of templateName: approved | pending | rejected | unknown
  templateStatus   String?
  /// When templateStatus was last fetched/synced from Meta
  templateSyncedAt DateTime?
  offerType        AutomationOfferType @default(none)
  /// Free-text offer value for custom offer type
  offerValue      String?
  /// Minimum days between two messages to the same client
  cooldownDays    Int                 @default(30)
  /// Only send to clients who have given WhatsApp/marketing opt-in
  requireOptIn    Boolean             @default(true)
  /// Test-only timing mode: "days" (production default) or "minutes" (admin/dev testing).
  /// Minute mode is only honored in non-production, by admins, or when
  /// ENABLE_AUTOMATION_MINUTE_TESTING=true — see lib/automation/minute-testing.ts.
  timingUnit           String         @default("days")
  /// Inactivity threshold in MINUTES — only used when timingUnit="minutes" (test mode).
  testThresholdMinutes Int?
  /// Cooldown in MINUTES between messages — only used when timingUnit="minutes" (test mode).
  testCooldownMinutes  Int?
  /// Timestamp of the first successful test send — used to track sandbox validation progress
  testSendPassedAt DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, type])
  @@index([businessId])
}

/// A single execution of an automation job (one per business per run).
model AutomationRun {
  id             String              @id @default(cuid())
  businessId     String
  type           AutomationType
  status         AutomationRunStatus @default(running)
  startedAt      DateTime            @default(now())
  finishedAt     DateTime?
  eligibleCount  Int                 @default(0)
  sentCount      Int                 @default(0)
  failedCount    Int                 @default(0)
  skippedCount   Int                 @default(0)
  createdAt      DateTime            @default(now())

  business Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  messages AutomationMessage[]

  @@index([businessId, type])
  @@index([businessId, status])
  @@index([businessId, startedAt])
}

/// One outbound message attempt per client per automation run.
model AutomationMessage {
  id                String                  @id @default(cuid())
  businessId        String
  runId             String
  clientId          String
  /// Optional — links back to the booking that triggered eligibility
  bookingId         String?
  type              AutomationType
  phone             String
  messageText       String
  /// Provider template id if required for approved templates
  templateId        String?
  status            AutomationMessageStatus @default(queued)
  providerMessageId String?
  failureReason     String?
  /// BCP 47 language code of the template actually used for the send (e.g. "he")
  templateLanguage  String?
  /// Phone Number ID the send was actually attempted with — lets admins verify
  /// the live id (e.g. a stale per-business connection vs the env value).
  phoneNumberId     String?
  /// Structured Meta Cloud API error fields, populated on provider failure.
  /// These are Meta's own diagnostic fields — safe to display, never a credential.
  errorCode         Int?
  errorSubcode      Int?
  errorType         String?
  errorFbtraceId    String?
  /// Sanitized raw Meta error object (JSON string of error.* only, no token/headers)
  errorRaw          String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  repliedAt         DateTime?
  retryCount        Int                     @default(0)
  lastRetryAt       DateTime?
  /// Origin of the message: cron, manual_owner, manual_admin, retry, or null for legacy records
  source            String?
  createdAt         DateTime                @default(now())

  business Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  run      AutomationRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  client   Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  booking  Booking?       @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([businessId, type])
  @@index([businessId, clientId])
  @@index([runId])
  @@index([status])
  @@index([providerMessageId])
}

// ---------------------------------------------------------------------------
// Booking payments (online clearing)
//
// Money is stored in MINOR units (agorot, Int) on these models — payment
// providers (PayPlus / Grow / Tranzila) all work in agorot. This is distinct
// from the Decimal(10,2) major-unit amounts used elsewhere (Service.price,
// Payment.amount); conversion happens at the boundary.
// ---------------------------------------------------------------------------

/// Per-business payment policy for the public booking page. One row per business.
/// Owners can configure this freely; real money never moves until a provider
/// connection is active AND server-side env gating is enabled.
model BusinessPaymentSettings {
  id                 String              @id @default(cuid())
  businessId         String              @unique
  /// Master switch — show an online payment step on the public booking page.
  enabled            Boolean             @default(false)
  provider           PaymentProviderKind @default(mock)
  requirement        PaymentRequirement  @default(none)
  /// Allow the customer to choose "I'll pay at the business" instead of paying now.
  allowPayAtBusiness Boolean             @default(true)
  /// Optional free-text instructions / cancellation note shown near the pay step.
  instructions       String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

/// Encrypted provider credentials + connection state. One row per business.
/// Mirrors WhatsAppConnection: secrets are AES-256-GCM encrypted and never
/// returned to the client.
model PaymentProviderConnection {
  id                   String                  @id @default(cuid())
  businessId           String                  @unique
  provider             PaymentProviderKind     @default(mock)
  status               PaymentConnectionStatus @default(not_connected)
  /// Encrypted JSON blob of provider credentials — never returned to the client.
  credentialsEncrypted String?
  /// Non-secret public config (e.g. terminal name, page UID) — safe to read.
  publicConfigJson     Json?
  lastVerifiedAt       DateTime?
  /// Last error message — safe to display in admin UI (never contains secrets).
  lastError            String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

/// One hosted-payment-link payment per booking. The booking itself stays
/// `pending` (never auto-confirmed); this record tracks the money. Payment is
/// only ever confirmed `paid` from a verified provider webhook / server check,
/// never from a client-side success redirect.
model BookingPayment {
  id                    String               @id @default(cuid())
  businessId            String
  bookingId            String                @unique
  clientId             String?
  provider             PaymentProviderKind
  status               BookingPaymentStatus  @default(pending)
  /// Amount to collect, in agorot.
  amountMinor          Int
  currency             String                @default("ILS")
  /// Hosted payment page URL the customer is sent to.
  paymentUrl           String?
  /// Provider's transaction / page reference — idempotency key for webhooks.
  providerTransactionId String?              @unique
  /// Sanitized provider payload (no PAN, no secrets) for debugging/audit.
  providerPayloadJson  Json?
  expiresAt            DateTime?
  paidAt               DateTime?
  failedAt             DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([businessId, status])
  @@index([businessId, bookingId])
}
