# חיבור למסד הנתונים (PostgreSQL)
# העתיקו קובץ זה ל-.env ומלאו את הערכים בהתאם לסביבה שלכם.
#
# פורמט:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
#
# ברירת המחדל מתאימה ל-Postgres המקומי שמופעל דרך docker-compose.yml.
# שימו לב: הקונטיינר ממופה לפורט 5433 במחשב המארח (ולא 5432), כדי לא להתנגש
# עם Postgres מקומי שאולי כבר תופס את 5432. ראו README.md → הקמה מקומית / פתרון תקלות.
DATABASE_URL="postgresql://beautiq_user:beautiq_password@localhost:5433/beautiq_dev?schema=public"

# פרודקשן (Vercel + Neon):
# חובה להשתמש ב-hostname של ה-pooler של Neon (מכיל "-pooler"), עם
# sslmode=require ו-connect_timeout=15 — מפחית כשלי P1001 חולפים ב-cold start.
# פורמט (להגדיר ב-Vercel Environment Variables, לא בקוד):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&connect_timeout=15"

# הגדרות אימות (Auth.js / NextAuth).
#
# מפתח סודי לחתימת והצפנת הסשנים. חובה למלא בערך אקראי וקבוע.
# יצירת ערך: openssl rand -base64 32
AUTH_SECRET=""

# כתובת הבסיס של האפליקציה.
# בפיתוח אפשר להשאיר ריק: trustHost מופעל ו-Auth.js גוזר את הכתובת מהבקשה,
# כך שהניתובים אחרי התחברות/הרשמה תמיד תואמים לפורט שבו השרת רץ בפועל.
# בפרודקשן הגדירו את הדומיין המלא, למשל:
# AUTH_URL="https://app.allura.info"

# כתובת הבסיס הציבורית של האפליקציה — משמשת לבניית קישורים חיצוניים
# (קישור לעמוד הציבורי של העסק, קישורי ביקורת והזמנה בהודעות WhatsApp).
# חשוף לדפדפן (NEXT_PUBLIC_). אם לא מוגדר, ברירת המחדל היא https://allura.info
# NEXT_PUBLIC_APP_URL="https://allura.info"

# ── התראות אימייל לבעלת העסק ──────────────────────────────────────────────────
#
# כשנכנסת בקשת תור חדשה מעמוד ההזמנות הציבורי, Allura שולחת לבעלת העסק
# אימייל אוטומטי (כדי שתדע גם בלי להיכנס למערכת). השליחה היא best-effort:
# אם השירות לא מוגדר — לא נשלח אימייל אך יצירת ההזמנה לא נכשלת.
#
# השליחה מתבצעת דרך Resend (https://resend.com). מלאו את שני הערכים כדי להפעיל:
#   RESEND_API_KEY — מפתח API מ-Resend
#   EMAIL_FROM     — כתובת שולח מאומתת בדומיין שלכם
# RESEND_API_KEY=""
# EMAIL_FROM="Allura <noreply@allura.info>"

# ── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────────
#
# ברירת מחדל: false — כל ההודעות נשלחות במצב פיתוח (לא נשלח בפועל).
# כדי להפעיל שליחה אמיתית דרך Meta WhatsApp Cloud API:
#   1. הגדירו ENABLE_REAL_WHATSAPP_SEND=true
#   2. הגדירו WHATSAPP_PROVIDER=meta_cloud_api
#   3. מלאו את פרטי הגישה של Meta למטה
#
# אם כל הפרטים הנדרשים לא מוגדרים, המערכת תחזור למצב כשל בטוח.
ENABLE_REAL_WHATSAPP_SEND=false
WHATSAPP_PROVIDER=meta_cloud_api

# Meta WhatsApp Cloud API credentials (נדרש רק כאשר ENABLE_REAL_WHATSAPP_SEND=true)
META_WHATSAPP_ACCESS_TOKEN=""
META_WHATSAPP_PHONE_NUMBER_ID=""
# גרסת Graph API — ברירת מחדל: v19.0
# META_WHATSAPP_API_VERSION=v19.0
# מזהה חשבון WhatsApp Business (WABA) — אופציונלי, לשימוש עתידי
# META_WHATSAPP_WABA_ID=""
# PIN בן 6 ספרות (אימות דו-שלבי) — נדרש רק להרצת scripts/register-whatsapp-number.ts
# META_WHATSAPP_REGISTRATION_PIN=""

# ── Env Fallback — חיבור זמני לבדיקה ────────────────────────────────────────
#
# WHATSAPP_USE_ENV_FALLBACK=true — מאפשר שליחה מהגדרות הסביבה כאשר אין
# חיבור WhatsApp מוגדר ברמת העסק בבסיס הנתונים.
# מיועד לבדיקות ולהרצת פיילוט ראשוני בלבד.
# בפרודקשן אמיתי עם לקוחות — כל עסק יחבר WhatsApp מהממשק שלו (Embedded Signup).
#
# אם true: המערכת תשתמש ב-META_WHATSAPP_ACCESS_TOKEN ו-META_WHATSAPP_PHONE_NUMBER_ID
#           גלובלית כאשר אין חיבור פר-עסק.
# אם false (ברירת מחדל): שליחה בפרודקשן דורשת WhatsAppConnection לכל עסק בנפרד.
WHATSAPP_USE_ENV_FALLBACK=false

# ── מצב בדיקה (Phase 2A) ─────────────────────────────────────────────────────
#
# WHATSAPP_TEST_MODE=true — שליחה אמיתית מותרת רק למספר WHATSAPP_TEST_PHONE.
# כל מספר אחר נחסם אוטומטית עם הסבר בממשק.
#
# לשליחה לכלל הלקוחות: הגדירו WHATSAPP_TEST_MODE=false.
# חשוב: הגדרת false מאפשרת שליחה לכלל הלקוחות — בצעו רק לאחר אישור מלא.
WHATSAPP_TEST_MODE=true
# מספר הטלפון היחיד המאושר לשליחה במצב בדיקה (פורמט E.164, לדוגמה: +972501234567)
WHATSAPP_TEST_PHONE=+972XXXXXXXXX

# ── התראת WhatsApp לבעלת העסק (אופציונלי) ─────────────────────────────────────
#
# כבוי כברירת מחדל. כש-ENABLE_OWNER_WHATSAPP_NOTIFICATION=true ויש לעסק מספר
# טלפון תקין — בנוסף לאימייל תישלח לבעלת העסק התראת WhatsApp קצרה על בקשת תור
# חדשה. best-effort בלבד: כישלון לעולם לא חוסם את יצירת ההזמנה. הערוץ העיקרי
# הוא תמיד אימייל.
# דרישה: ההתראה נשלחת דרך תבנית Meta מאושרת בשם business_new_booking_he
# (UTILITY, שפה he) שחייבת להיות מאושרת ב-WABA המנוהל של Allura לפני הפעלת הדגל.
# ENABLE_OWNER_WHATSAPP_NOTIFICATION=false

# ── תזמון אוטומציות בדקות (בדיקות בלבד) ───────────────────────────────────────
#
# תזמון האוטומציות בייצור הוא תמיד לפי ימים. כדי לבדוק זרימות במהירות אפשר
# למדוד את סף חוסר-הפעילות וה-cooldown בדקות במקום בימים — אך זה מיועד לבדיקות.
#
# מצב דקות זמין כאשר אחד מאלה מתקיים:
#   - NODE_ENV !== "production" (פיתוח/בדיקות)
#   - המשתמש הוא admin
#   - ENABLE_AUTOMATION_MINUTE_TESTING=true
#
# בעלי עסק רגילים בייצור לא רואים/לא מפעילים מצב דקות אלא אם הדגל למטה דלוק.
# גם cron מכבד מצב דקות בייצור רק כשהדגל דלוק — אחרת חוזר אוטומטית לימים.
# מצב דקות לעולם אינו עוקף את מנגנוני האבטחה (opt-in, marketing, unsubscribe,
# upcoming booking, cooldown, provider/env guards, businessId scoping).
# ENABLE_AUTOMATION_MINUTE_TESTING=false

# ── Meta Webhooks (Phase 2C) ──────────────────────────────────────────────────
#
# META_WEBHOOK_VERIFY_TOKEN — טוקן שרירותי שתגדירו גם כאן וגם בממשק Meta.
#   Meta ישלח את הטוקן הזה בעת רישום ה-Webhook; המערכת תוודא שהוא תואם.
#   צרו ערך אקראי: openssl rand -hex 16
META_WEBHOOK_VERIFY_TOKEN=""

# META_WEBHOOK_APP_SECRET — ה-App Secret של אפליקציית Meta שלכם.
#   נמצא ב: Meta App Dashboard → Settings → Basic → App Secret.
#   משמש לאימות חתימת HMAC-SHA256 על כל בקשת POST נכנסת.
#   אם לא מוגדר, אימות החתימה יידלג (מותאם לפיתוח בלבד — הגדירו בפרודקשן).
META_WEBHOOK_APP_SECRET=""
#
# כתובת ה-Webhook לרישום ב-Meta App Dashboard:
#   https://<your-domain>/api/whatsapp/webhook

# ── Embedded Signup — חיבור WhatsApp אוטומטי לכל עסק (Production) ─────────────
#
# מאפשר לבעל העסק לחבר WhatsApp Business בלחיצת כפתור, ללא הזנת טוקנים ידנית.
# החיבור משתמש ב-Facebook Login for Business + Meta Embedded Signup.
#
# WHATSAPP_CREDENTIALS_ENCRYPTION_KEY — מפתח להצפנת טוקני הגישה של העסקים
#   לפני שמירתם בבסיס הנתונים (AES-256-GCM). חובה בפרודקשן.
#   צרו ערך אקראי (32 בייט hex): openssl rand -hex 32
WHATSAPP_CREDENTIALS_ENCRYPTION_KEY=""

# META_APP_ID / META_APP_SECRET — פרטי אפליקציית Meta (Server-side).
#   נמצאים ב: Meta App Dashboard → Settings → Basic.
#   משמשים להחלפת קוד ההרשאה בטוקן גישה של העסק.
META_APP_ID=""
META_APP_SECRET=""

# ערכי Client-side (חשופים לדפדפן — חייבים להתחיל ב-NEXT_PUBLIC_):
#   NEXT_PUBLIC_META_APP_ID    — אותו App ID, לטעינת ה-Facebook SDK בדפדפן.
#   NEXT_PUBLIC_META_CONFIG_ID — מזהה תצורת "Facebook Login for Business"
#                                (Meta App → Facebook Login for Business → Configurations).
#   NEXT_PUBLIC_META_GRAPH_VERSION — גרסת Graph API (ברירת מחדל v19.0).
NEXT_PUBLIC_META_APP_ID=""
NEXT_PUBLIC_META_CONFIG_ID=""
# NEXT_PUBLIC_META_GRAPH_VERSION=v19.0

# ── Cron Jobs ────────────────────────────────────────────────────────────────
#
# CRON_SECRET — טוקן סודי לאימות קריאות cron נכנסות.
#   Vercel שולח אוטומטית את הטוקן הזה ב-header: Authorization: Bearer <CRON_SECRET>
#   בעת הפעלת ה-cron שמוגדר ב-vercel.json.
#   צרו ערך אקראי: openssl rand -hex 32
CRON_SECRET=""

# ── מנוי Allura של בעלת העסק (Grow / משולם, דרך Make) ────────────────────────
#
# החיוב החודשי של בעלת העסק עבור תוכנית Allura (פרימיום ₪149 / פלטינום ₪249),
# דרך שער התשלומים Grow (משולם) — בחיוב חוזר אוטומטי (הוראת קבע).
#
# יצירת קישור התשלום מתווכת דרך תרחיש (scenario) ב-Make: פרטי חשבון ה-Grow
# שמורים בחיבור ב-Make, כך שכאן לא נשמרים אישורי Grow API כלל — רק כתובת
# ה-Webhook של התרחיש. אישור התשלום עצמו מגיע ישירות מ-Grow לשרת שלנו
# (notifyUrl → /api/subscription/webhook), ו-Grow מחייב את הוראת הקבע אוטומטית
# כל חודש ומדווח שוב לאותו webhook — אין צורך ב-cron אצלנו.
#
# ברירת מחדל: כבוי. כשכבוי, מסך /subscribe מפעיל את התוכנית מיידית (מצב פיתוח)
# ללא סליקה אמיתית, כדי לשמור על האפליקציה ניתנת להרצה מקומית.
#
# להפעלת חיוב אמיתי:
#   1. SUBSCRIPTIONS_ENABLED=true
#   2. MAKE_GROW_CREATE_LINK_WEBHOOK_URL = כתובת ה-Custom webhook של תרחיש Make
#      (התרחיש: Webhook → Grow "Create Payment Link" (recurring) → Webhook Response
#       שמחזיר JSON: { "url": ..., "processId": ..., "processToken": ... })
#   3. ודאו ש-NEXT_PUBLIC_APP_URL מוגדר (לבניית notifyUrl/successUrl)
SUBSCRIPTIONS_ENABLED=false
MAKE_GROW_CREATE_LINK_WEBHOOK_URL=""
# MAKE_GROW_APPROVE_WEBHOOK_URL — אופציונלי. תרחיש Make נוסף שקורא ל-Grow
#   "Approve Transaction" כדי לעצור חיוויים חוזרים. לא חובה (ה-webhook אידמפוטנטי).
MAKE_GROW_APPROVE_WEBHOOK_URL=""
# MAKE_GROW_CANCEL_WEBHOOK_URL — אופציונלי. תרחיש Make שמבטל את הוראת הקבע ב-Grow
#   (Make "Make an API Call" לנקודת הביטול, לפי directDebitId). אם לא מוגדר,
#   ביטול המנוי מתבצע מקומית (הגישה עד סוף התקופה) ואת עוצרת את הוראת הקבע ידנית
#   מלוח הבקרה של Grow.
MAKE_GROW_CANCEL_WEBHOOK_URL=""
# MAKE_WEBHOOK_SHARED_SECRET — אופציונלי. סוד משותף שנשלח בגוף הבקשה ל-Make,
#   שניתן לסנן לפיו בתרחיש כדי לוודא שהבקשה הגיעה מ-Allura.
MAKE_WEBHOOK_SHARED_SECRET=""

# ── ניטור ובנייה (Monitoring & Build) ─────────────────────────────────────────
#
# SKIP_ENV_VALIDATION=true — מדלג על אימות משתני הסביבה בעליית השרת.
#   מיועד לסביבות בנייה/CI בלבד, שאין בהן את כל הסודות. אל תפעילו בפרודקשן.
# SKIP_ENV_VALIDATION=false
